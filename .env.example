# Krusch Memory MCP — Environment Variables
# Copy this file to .env and adjust as needed.

# Database mode: "sqlite" (default) or "postgres"
DB_MODE=sqlite

# PostgreSQL connection string (only used when DB_MODE=postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5441/krusch_memory

# SQLite file path (only used when DB_MODE=sqlite)
SQLITE_FILE=./krusch_memory.db

# Ollama endpoint for local embeddings
OLLAMA_URL=http://localhost:11434

# Embedding model (must match the vector dimensions in schema.sql)
EMBED_MODEL=qwen2.5-coder:1.5b

# Auto-tagging: set to "true" to auto-generate tags via local LLM
AUTO_TAG=false

# LLM model for auto-tagging
TAG_MODEL=llama3.2

# LLM model for memory consolidation (defaults to TAG_MODEL)
# SUMMARIZE_MODEL=llama3.2

# Exponential decay rate for temporal memory scoring (0.0 = disabled)
DECAY_RATE=0.01

# Maximum content length in bytes (default 50KB)
MAX_CONTENT_LENGTH=51200
